<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- dotnet global tool packaging -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>whatismyip</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>

    <!-- NuGet metadata (edit before publishing publicly) -->
    <PackageId>whatismyip</PackageId>
    <Version>1.0.0</Version>
    <Authors>Sebastian Just Mikkelsen</Authors>
    <Description>Cross-platform CLI tool that prints your public and internal (LAN) IP addresses.</Description>
    <PackageTags>cli;ip;network;tool</PackageTags>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
